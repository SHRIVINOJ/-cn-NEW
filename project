        "import pandas as pd\n",
        "import ipywidgets as widgets\n",
        "from IPython.display import display, HTML\n",
        "\n",
        "# Load the dataset\n",
        "df = pd.read_csv('heart.csv')\n",
        "\n",
        "def run_comprehensive_analysis(b):\n",
        "    with output_area:\n",
        "        output_area.clear_output()\n",
        "        display(HTML(\"<h3>Generating Diagnostic Report...</h3>\"))\n",
        "\n",
        "        selected_patient = df.loc[patient_dropdown.value]\n",
        "\n",
        "        # Calculate a clinical risk score based on simple weighted logic\n",
        "        risk_score = 0\n",
        "        if selected_patient['age'] > 50:\n",
        "            risk_score += 20\n",
        "        if selected_patient['chol'] > 240:\n",
        "            risk_score += 30\n",
        "        if selected_patient['cp'] > 1:\n",
        "            risk_score += 25\n",
        "\n",
        "        # Professional Hospital UI Output\n",
        "        report_html = f\"<div style='border: 3px solid #0056b3; padding: 20px; border-radius: 10px; width: 350px; font-family: Arial, sans-serif;'>\"\n",
        "        report_html += f\"<h2 style='color: #0056b3; margin-top: 0;'>Clinical Diagnostic Report</h2>\"\n",
        "        report_html += f\"<p><strong>Patient ID:</strong> {patient_dropdown.value}</p>\"\n",
        "        report_html += f\"<p><strong>Age:</strong> {selected_patient['age']}</p>\"\n",
        "        report_html += f\"<p><strong>Chest Pain Type:</strong> {selected_patient['cp']}</p>\"\n",
        "        report_html += f\"<p><strong>Cholesterol Level:</strong> {selected_patient['chol']} mg/dl</p>\"\n",
        "\n",
        "        if risk_score > 50:\n",
        "            report_html += \"<p style='color: white; background-color: #dc3545; padding: 10px; border-radius: 5px;'><strong>Status:</strong> ⚠️ High Risk Detected</p>\"\n",
        "        else:\n",
        "            report_html += \"<p style='color: white; background-color: #28a745; padding: 10px; border-radius: 5px;'><strong>Status:</strong> ✅ Within Normal Parameters</p>\"\n",
        "\n",
        "        report_html += f\"<p><strong>Calculated Risk Score:</strong> {risk_score}/100</p>\"\n",
        "        report_html += \"</div>\"\n",
        "\n",
        "        display(HTML(report_html))\n",
        "\n",
        "patient_dropdown = widgets.Dropdown(options=df.index.tolist(), description='Select Patient:')\n",
        "analyze_button = widgets.Button(description=\"Analyze Vitals\", button_style='primary', icon='heartbeat')\n",
        "analyze_button.on_click(run_comprehensive_analysis)\n",
        "\n",
        "output_area = widgets.Output()\n",
        "\n",
        "display(widgets.VBox([patient_dropdown, analyze_button, output_area]))"
